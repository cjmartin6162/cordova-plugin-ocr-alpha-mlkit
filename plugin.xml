<?xml version="1.0" encoding="utf-8"?>
<plugin id="cordova-plugin-ocr-alpha-mlkit" version="1.0.3"
  xmlns="http://apache.org/cordova/ns/plugins/1.0"
  xmlns:android="http://schemas.android.com/apk/res/android">

  <name>Cordova OCR Alpha ML Kit</name>
  <description>Static-image OCR via ML Kit on-device text recognition</description>
  <license>MIT</license>
  <keywords>cordova,ocr,mlkit,text-recognition</keywords>

  <engines>
    <engine name="cordova" version=">=12.0.0" />
    <engine name="cordova-ios" version=">=7.1.1" />
  </engines>

  <!-- ML Kit Text Recognition v2 requires at least iOS 12 (see Google ML Kit release notes). -->
  <preference name="deployment-target" value="12.0" />

  <js-module src="www/ocr.js" name="Ocr">
    <clobbers target="cordova.plugins.Ocr" />
  </js-module>

  <platform name="android">
    <config-file target="res/xml/config.xml" parent="/*">
      <feature name="Ocr">
        <param name="android-package" value="com.example.ocr.Ocr" />
      </feature>
    </config-file>
    <source-file src="src/android/Ocr.java" target-dir="src/com/example/ocr" />
    <framework src="com.google.mlkit:text-recognition:16.0.1" />
  </platform>

  <platform name="ios">
    <!-- Self-register the native plugin; host app config.xml does not need a manual feature. -->
    <config-file target="config.xml" parent="/*">
      <feature name="Ocr">
        <param name="ios-package" value="Ocr" />
      </feature>
    </config-file>

    <header-file src="src/ios/Ocr.h" />
    <source-file src="src/ios/Ocr.m" />

    <!-- Single umbrella subspec pulls consistent MLKitTextRecognition* and MLKitVision deps (CocoaPods on cordova-ios 7.1.x and 8.x). -->
    <pod name="GoogleMLKit/TextRecognition" spec="8.0.0" />
  </platform>
</plugin>
